  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Tutorial2
  pathFollower: {fileID: 2102062177}
  part1TextDialogue1: 'Yes, we made it to Maria!

    Let''s keep on going :D'
  mapCenter: {fileID: 0}
  zoomAmount: 50
  part2TextDialogue1: 'Ah, crap! We woke the baby up D:

    Try calming them down!'
  part2TextDialogue2: HURRY, CALM IT DOWN, GUARDS ARE GOING TO COME!!
  part2TextDialogue3: Phew, I got nervous there, glad you could calm the baby down!
  part2Baby: {fileID: 0}
  part3TextDialogue1: 'OH DRACULA! Is that a priest?

    AND THEY HAVE HOLY WATER?!'
  part3TextDialogue2: Could you try shaking their water away?
  part3TextDialogue3: But don't forget to be quick about it!
  part3Priest: {fileID: 0}
